---
const REG = 'https://app.fineintegrity.com/register';
const heroCTA = `${REG}?utm_source=website&utm_medium=hero&utm_campaign=free-trial`;
---

<section class="hero" aria-label="Hero">
  <div class="container hero-inner">

    <!-- Text column -->
    <div class="hero-text">
      <span class="eyebrow">🎉 Festival Ready</span>

      <h1 class="hero-headline">
        Your Diwali campaigns.<br />Ready in 5 minutes.
      </h1>

      <p class="hero-sub">
        Describe your offer in plain English or Hindi — AI creates a professional,
        branded campaign in under 15 seconds, for WhatsApp and email.
      </p>

      <a
        href={heroCTA}
        class="btn hero-btn"
        data-cta
        data-cta-location="hero"
      >
        Start Free Trial
        <span class="btn-sub">No Credit Card Required</span>
      </a>

      <div class="trust-row" aria-label="Key facts">
        <div class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Free for 1 month</div>
        <div class="trust-item"><span class="trust-dot" aria-hidden="true"></span>WhatsApp + Email</div>
        <div class="trust-item"><span class="trust-dot" aria-hidden="true"></span>Built for Indian festivals</div>
      </div>
    </div>

    <!-- WhatsApp campaign mockup — decorative, shows a sample Prachar-generated campaign -->
    <div class="hero-visual" aria-hidden="true">
      <div class="wa-card">
        <!-- Header image area (festival motif) -->
        <div class="wa-img">
          <div class="wa-diyas">🪔 🪔 🪔</div>
          <p class="wa-hindi">दीपावली की शुभकामनाएं</p>
          <p class="wa-eng">Diwali Wishes from Shree Garments</p>
        </div>

        <!-- Message body -->
        <div class="wa-body">
          <p class="wa-title">🎉 Diwali Special — 30% Off All Sarees</p>
          <p class="wa-text">Celebrate Diwali with our exclusive collection. Offer valid till 2 Nov 2026.</p>
          <p class="wa-contact">📍 Shree Ladies Garments, Pune &nbsp;·&nbsp; 📞 98765 43210</p>
        </div>

        <!-- CTA button row -->
        <div class="wa-cta-row">
          <span class="wa-cta-btn">Shop Now →</span>
        </div>

        <!-- Required opt-out footer -->
        <div class="wa-stop">Reply STOP to unsubscribe</div>

        <!-- Prachar attribution badge -->
        <div class="wa-badge">✨ Generated by Prachar in 11 seconds</div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, var(--c-indigo-dark) 0%, var(--c-indigo-mid) 60%, var(--c-indigo-soft) 100%);
    padding-block: calc(var(--header-h) + var(--s-12)) var(--s-12);
    position: relative;
    overflow: hidden;
  }

  /* Decorative warm glow behind text */
  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -5%;
    width: 50%;
    height: 70%;
    background: radial-gradient(ellipse at top right, rgba(249,115,22,.35) 0%, transparent 60%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .hero { padding-block: calc(var(--header-h) + var(--s-20)) var(--s-20); }
  }

  /* ---- Two-column layout on tablet+ ---- */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .hero-inner { grid-template-columns: 1fr 1fr; }
  }

  /* ---- Text column ---- */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }

  .hero-headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
    line-height: 1.15;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--c-primary-light);
    line-height: 1.65;
    max-width: 480px;
  }

  .hero-btn { font-size: 1.0625rem; padding: 14px 32px; }

  /* ---- WhatsApp mockup ---- */
  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .wa-card {
    background: var(--c-surface);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--sh-3);
    max-width: 340px;
    width: 100%;
  }

  .wa-img {
    background: linear-gradient(135deg, #1a0533 0%, #2D1570 50%, #4A1055 100%);
    padding: var(--s-8) var(--s-6);
    text-align: center;
  }
  .wa-diyas  { font-size: 1.75rem; margin-bottom: var(--s-2); }
  .wa-hindi  { color: var(--c-primary-light); font-size: 1.0625rem; font-weight: 700; margin-bottom: 4px; }
  .wa-eng    { color: rgba(255,255,255,.6); font-size: .75rem; }

  .wa-body   { padding: var(--s-4) var(--s-5); border-bottom: 1px solid var(--c-border); }
  .wa-title  { font-size: .9375rem; font-weight: 700; color: var(--c-indigo-dark); margin-bottom: 6px; }
  .wa-text   { font-size: .875rem; color: var(--c-muted); line-height: 1.55; margin-bottom: 6px; }
  .wa-contact { font-size: .75rem; color: var(--c-muted); }

  .wa-cta-row {
    padding: var(--s-3) var(--s-5);
    border-bottom: 1px solid var(--c-border);
    display: flex;
    justify-content: center;
  }
  .wa-cta-btn {
    color: #128C7E;
    font-weight: 600;
    font-size: .875rem;
    letter-spacing: .1px;
  }

  .wa-stop {
    padding: var(--s-2) var(--s-5);
    font-size: .6875rem;
    color: var(--c-muted);
    text-align: center;
    background: #f5f5f5;
  }

  .wa-badge {
    padding: var(--s-2) var(--s-5);
    font-size: .75rem;
    font-weight: 600;
    color: var(--c-primary);
    text-align: center;
    background: rgba(249,115,22,.06);
  }
</style>
