{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/*.{css,js,png,jpg,jpeg,webp,svg,ico,gif,woff2,txt,xml,json}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), camera=(), microphone=()"
  }
}
